{
  "name": "pc_store",
  "version": "1.0.0",
  "description": "Hệ thống quản lý và bán linh kiện PC Store chuyên nghiệp",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "d:up": "docker-compose up -d",
    "d:down": "docker-compose down",
    "d:restart": "docker-compose restart app",
    "d:logs": "docker-compose logs -f app",
    "db:migrate": "docker-compose exec app npx knex migrate:latest",
    "db:rollback": "docker-compose exec app npx knex migrate:rollback --all",
    "db:seed": "docker-compose exec app npx knex seed:run",
    "db:make-migrate": "npx knex migrate:make",
    "db:make-seed": "npx knex seed:make",
    "test": "cross-env NODE_ENV=test jest --watchAll --detectOpenHandles"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
