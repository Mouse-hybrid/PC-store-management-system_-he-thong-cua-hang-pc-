# --- DEPENDENCIES ---
# Không đẩy thư viện lên Git vì chúng rất nặng, sẽ được cài lại bằng 'npm install'
node_modules/
/dist
/build

# --- ENVIRONMENT & SECRETS ---
# CỰC KỲ QUAN TRỌNG: Không bao giờ đẩy tệp chứa mật khẩu/token lên Git
.env
.env.test
.env.production
.env.local

# --- HTTPS CERTIFICATES ---
# Không đẩy chứng chỉ SSL/TLS lên Git để đảm bảo an toàn cho server
certs/*.key
certs/*.cert
certs/*.pem
certs/*.pfx

# --- LOGS ---
# Chỉ giữ lại cấu trúc folder logs/, không lưu nội dung các tệp log
logs/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
!logs/.gitkeep

# --- DATABASE ---
# Nếu có sử dụng SQLite hoặc các tệp DB cục bộ
*.sqlite
*.db

# --- DOCKER ---
# Các tệp dữ liệu phát sinh từ Docker volumes (nếu có để trong folder dự án)
.docker_data/

# --- TESTING ---
# Kết quả kiểm thử (nếu bạn sử dụng Jest coverage)
coverage/
.nyc_output/

# --- IDE & SYSTEM ---
# Các tệp cấu hình riêng của máy tính hoặc trình soạn thảo (VS Code, WebStorm)
.vscode/
.idea/
.DS_Store
Thumbs.db